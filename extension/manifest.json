{
  "manifest_version": 3,
  "name": "Ghost in the Loop",
  "version": "6.7.0",
  "description": "👻 AI workflow engine — roadmap autopilot, prompt queue, handoff capsules, personas, diagnostics.",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://www.perplexity.ai/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*",
        "https://copilot.microsoft.com/*",
        "https://grok.com/*",
        "https://claude.ai/*",
        "https://manus.im/*",
        "https://www.manus.im/*",
        "https://chat.mistral.ai/*",
        "https://kimi.com/*",
        "https://www.kimi.com/*",
        "https://kimi.moonshot.cn/*",
        "https://chat.qwen.ai/*",
        "https://meta.ai/*",
        "https://www.meta.ai/*",
        "https://poe.com/*",
        "https://huggingface.co/chat*",
        "https://you.com/*",
        "https://pi.ai/*",
        "https://chat.z.ai/*",
        "https://genspark.ai/*",
        "https://www.genspark.ai/*",
        "https://chat.minimax.io/*",
        "https://lmarena.ai/*",
        "https://duck.ai/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon-48.png",
    "96": "icon-96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ghost-in-the-loop@mshneur.dev",
      "strict_min_version": "109.0"
    }
  }
}