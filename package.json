{
  "name": "ghost-in-the-loop",
  "version": "7.0.0",
  "description": "Ghost in the Loop — test harness",
  "scripts": {
    "build": "npm run build:extension",
    "build:extension": "node scripts/build-extension.js",
    "check:generated": "node scripts/build-extension.js --check",
    "test": "npm run check:generated && jest",
    "test:unit": "jest",
    "test:e2e": "playwright test",
    "test:all": "jest && playwright test",
    "lint": "node --check ghost-in-the-loop.user.js && node --check extension/content.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "roots": ["<rootDir>/tests"],
    "testMatch": ["**/*.test.js"],
    "setupFiles": ["./tests/setup.js"],
    "coverageReporters": ["text", "lcov"],
    "modulePathIgnorePatterns": ["<rootDir>/dev/"]
  }
}
